# ==========================================
# Node.js / React / MongoDB .gitignore
# ==========================================

# Dependencies - Root level
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Client dependencies
client/node_modules/
client/npm-debug.log*
client/yarn-debug.log*
client/yarn-error.log*

# Server dependencies
server/node_modules/
server/npm-debug.log*
server/yarn-debug.log*
server/yarn-error.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage/
*.lcov
client/coverage/
server/coverage/

# nyc test coverage
.nyc_output
client/.nyc_output/
server/.nyc_output/

# Build directories
build/
dist/
out/
client/build/
client/dist/
client/out/
server/build/
server/dist/
server/out/

# React specific build outputs
client/build
client/storybook-static

# Production builds
client/public/build/
server/public/

# Cache directories
.cache/
.parcel-cache/
client/.cache/
client/.parcel-cache/
server/.cache/
server/.parcel-cache/

# Next.js build output
.next/
out/
client/.next/
client/out/

# Nuxt.js build / generate output
.nuxt/
dist/
client/.nuxt/
client/dist/

# Gatsby files
.cache/
public/
client/.cache/
client/public/

# Vuepress build output
.vuepress/dist/
client/.vuepress/dist/

# Docusaurus cache and generated files
.docusaurus/
client/.docusaurus/

# TypeScript cache
*.tsbuildinfo
client/*.tsbuildinfo
server/*.tsbuildinfo

# Optional npm cache directory
.npm/
client/.npm/
server/.npm/

# Optional eslint cache
.eslintcache
client/.eslintcache
server/.eslintcache

# Optional stylelint cache
.stylelintcache
client/.stylelintcache
server/.stylelintcache

# Microbundle cache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/
client/.rpt2_cache/
client/.rts2_cache_cjs/
client/.rts2_cache_es/
client/.rts2_cache_umd/
server/.rpt2_cache/
server/.rts2_cache_cjs/
server/.rts2_cache_es/
server/.rts2_cache_umd/

# Optional REPL history
.node_repl_history
client/.node_repl_history
server/.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variable files
.env
.env.development.local
.env.test.local
.env.production.local
.env.local
client/.env*
server/.env*

# parcel-bundler cache
.cache
.parcel-cache
client/.cache
client/.parcel-cache
server/.cache
server/.parcel-cache

# Serverless directories
.serverless/
client/.serverless/
server/.serverless/

# FuseBox cache
.fusebox/
client/.fusebox/
server/.fusebox/

# DynamoDB Local files
.dynamodb/
client/.dynamodb/
server/.dynamodb/

# TernJS port file
.tern-port
client/.tern-port
server/.tern-port

# Stores VSCode versions used for testing VSCode extensions
.vscode-test/
client/.vscode-test/
server/.vscode-test/

# yarn v2
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*
client/.yarn/cache
client/.yarn/unplugged
client/.yarn/build-state.yml
client/.yarn/install-state.gz
client/.pnp.*
server/.yarn/cache
server/.yarn/unplugged
server/.yarn/build-state.yml
server/.yarn/install-state.gz
server/.pnp.*

# ==========================================
# IDE and Editor Files
# ==========================================

# IntelliJ based IDEs
.idea/
client/.idea/
server/.idea/

# VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
client/.vscode/
server/.vscode/

# ==========================================
# OS Generated Files
# ==========================================

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
client/.DS_Store
client/.DS_Store?
client/._*
client/.Spotlight-V100
client/.Trashes
client/ehthumbs.db
client/Thumbs.db
server/.DS_Store
server/.DS_Store?
server/._*
server/.Spotlight-V100
server/.Trashes
server/ehthumbs.db
server/Thumbs.db

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
client/Thumbs.db
client/ehthumbs.db
client/Desktop.ini
server/Thumbs.db
server/ehthumbs.db
server/Desktop.ini

# Linux
*~

