# Environment Variables for User Management System

# MongoDB Connection String
# For local development: mongodb://localhost:27017/user-management
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/user-management
MONGO_URI=mongodb://localhost:27017/user-management

# Server Port (optional, defaults to 5000)
PORT=5000

# Node Environment (automatically set by deployment platforms)
NODE_ENV=development